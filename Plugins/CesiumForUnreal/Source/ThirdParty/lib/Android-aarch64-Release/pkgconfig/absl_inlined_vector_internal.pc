prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: absl_inlined_vector_internal
Description: Abseil inlined_vector_internal library
URL: https://abseil.io/
Version: 20260107

Libs: "-L${libdir}"
Requires: absl_base_internal = 20260107, absl_compressed_tuple = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_memory = 20260107, absl_span = 20260107, absl_type_traits = 20260107
Cflags: "-I${includedir}" -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX

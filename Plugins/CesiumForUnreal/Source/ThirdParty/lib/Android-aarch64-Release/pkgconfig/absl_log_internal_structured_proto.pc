prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: absl_log_internal_structured_proto
Description: Abseil log_internal_structured_proto library
URL: https://abseil.io/
Version: 20260107

Libs: "-L${libdir}" -labsl_log_internal_structured_proto
Requires: absl_log_internal_proto = 20260107, absl_config = 20260107, absl_span = 20260107, absl_strings = 20260107, absl_variant = 20260107
Cflags: "-I${includedir}" -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX

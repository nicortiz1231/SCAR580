prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: absl_random_internal_entropy_pool
Description: Abseil random_internal_entropy_pool library
URL: https://abseil.io/
Version: 20260107

Libs: "-L${libdir}" -labsl_random_internal_entropy_pool
Requires: absl_base = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_random_internal_platform = 20260107, absl_random_internal_randen = 20260107, absl_random_internal_seed_material = 20260107, absl_random_seed_gen_exception = 20260107, absl_span = 20260107, absl_synchronization = 20260107
Cflags: "-I${includedir}" -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX

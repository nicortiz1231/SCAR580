prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: absl_utf8_for_code_point
Description: Abseil utf8_for_code_point library
URL: https://abseil.io/
Version: 20260107

Libs: "-L${libdir}" -labsl_utf8_for_code_point
Requires: absl_config = 20260107
Cflags: "-I${includedir}" -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -Wno-unused-command-line-argument -DNOMINMAX
